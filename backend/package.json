{
  "name": "electiq-backend",
  "version": "1.0.0",
  "description": "ElectIQ — AI-powered election companion backend powered by Gemini and Firebase",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix"
  },
  "dependencies": {
    "@google/generative-ai": "^0.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "branches": 90,
        "functions": 85,
        "lines": 90
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/services/firebase.js",
      "!src/services/gemini.js",
      "!src/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
