# ═══════════════════════════════════════════════════════════════
# ElectIQ Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it is in .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Google Gemini AI ──────────────────────────────────────────
# Required. Powers all AI features: chat, quiz, checklist generation.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase ──────────────────────────────────────────────────
# Required. Your Realtime Database URL from Firebase Console → RTDB.
# Format: https://YOUR-PROJECT-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Required. Firebase Admin SDK service account JSON.
# How to get: Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON → paste ENTIRE content
# on a SINGLE LINE here (no line breaks inside the JSON).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com","client_id":"123456","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxx%40your-project.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Optional. Firebase Cloud Storage bucket for analytics snapshots.
# Format: your-project-id.appspot.com
# If not set, snapshot archiving is silently disabled.
GCLOUD_STORAGE_BUCKET=your-project-id.appspot.com

# ── Server ────────────────────────────────────────────────────
# Port the Express server listens on. Cloud Run sets this automatically.
PORT=3001

# Node environment. Set to 'production' in deployed environments.
# Controls whether stack traces are returned in error responses.
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
# URL of your frontend for CORS and Socket.IO origin policy.
# Local dev: http://localhost:5000
# Production: your Firebase Hosting or Cloud Run URL
# Set to * to allow all origins (development only — not recommended for production)
FRONTEND_URL=http://localhost:5000
